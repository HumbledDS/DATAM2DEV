# Configuration des clés API pour l'Assistant IA Multi-Provider

# Claude (Anthropic)
# Obtenir la clé: https://console.anthropic.com
# Commence par: sk-ant-
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ChatGPT (OpenAI)
# Obtenir la clé: https://platform.openai.com/account/api-keys
# Commence par: sk-
OPENAI_API_KEY=sk-your-api-key-here

#pip install openai


# Grok (X AI)
# Obtenir la clé: https://console.x.ai
# Format: chaîne de caractères
XAI_API_KEY=your-api-key-here

# DeepSeek
# Obtenir la clé: https://platform.deepseek.com
# Commence par: sk-
DEEPSEEK_API_KEY=sk-your-api-key-here

# Hugging Face
# Obtenir le token: https://huggingface.co/settings/tokens
# Commence par: hf_
HUGGINGFACE_API_KEY=hf_your-token-here

# Configuration du serveur (optionnel)
# PORT=8000
# HOST=0.0.0.0
